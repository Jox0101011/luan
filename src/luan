#!/usr/bin/env bash

set -euo pipefail

VERSION="0.1"
file=""
encode_type=""

start_banner() {
    echo -e "\n\t\t\t\e[1;34mWelcome\e[0m\t\t\t\e[1;31mLUAN\e[0m\t\t\t \e[1;35mv$VERSION\e[0m\n"
}

version_view() {
    printf "\nluan in v%s\n\n" "$VERSION"
}

usage() {
    cat << EOF
Uso: $0 [-v] [-h] [-b] [-f <file> [--encode <type>]]

Opções:
  -v                 Shows the version.
  -h                 Shows this message of help.
  -b                 Shows the initial banner.
  -f <file>       Display the file's contents and word count.
                     Can be used with --encode for encryption.
  --encode <type>    Encrypts the specified file with -f.
                     Suportted types: sha256, sha1.
EOF
}

while getopts "vhbf:" opt; do
    case $opt in
        v) version_view; exit 0 ;;
        h) usage; exit 0 ;;
        b) start_banner ;;
        f) file="$OPTARG" ;;
        \?) echo "Erro: Opção inválida: -$OPTARG" >&2; usage; exit 1 ;;
        :) echo "Erro: A opção -$OPTARG requer um argumento." >&2; usage; exit 1 ;;
    esac
done

shift $((OPTIND - 1))

if [[ "$1" == "--encode" ]]; then
    shift
    if [[ "$#" -eq 0 ]]; then
        echo "Erro: The optiond --encode need a encryption type (sha256 ou sha1)." >&2
        usage
        exit 1
    fi
    encode_type="$1"
fi

if [[ -n "$file" ]]; then
    if [[ -d "$file" ]]; then
        echo -e "\e[1;41mERRO:\e[0m '$file' is a directory, not a file." >&2
        exit 1
    fi

    if [[ ! -f "$file" ]]; then
        echo -e "\e[1;41mERRO:\e[0m File not found: '$file'" >&2
        exit 1
    fi

    if [[ -n "$encode_type" ]]; then
        if [[ "$encode_type" == "sha256" ]]; then
            echo "Encrypting with SHA256..."
            if command -v pv >/dev/null 2>&1; then
                cat "$file" | sha256sum | pv
            else
                cat "$file" | sha256sum
            fi
            echo "Concluído."
        elif [[ "$encode_type" == "sha1" ]]; then
            echo "Encrypting with SHA1..."
            if command -v pv >/dev/null 2>&1; then
                cat "$file" | sha1sum | pv
            else
                cat "$file" | sha1sum
            fi
            echo "Concluído."
        else
            echo -e "\e[1;41mERRO:\e[0m Encryption type '$encode_type' não suportado." >&2
            usage
            exit 1
        fi
    else
        echo "Displaying content from '$file'..."
        more "$file"
        echo -e "\nCon '$file':"
        wc "$file"
    fi
fi
